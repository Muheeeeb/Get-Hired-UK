# ---------------------------------------------------------------------------
# Production .env for the Get Hired UK API  →  /srv/gethired/server/.env
# Generate the three secrets with:  openssl rand -base64 36
# Lock the file down:  chmod 600 .env  &&  chown gethired:gethired .env
# ---------------------------------------------------------------------------

NODE_ENV=production
PORT=4000
# Caddy proxies to loopback; leave HOST unset (defaults to 127.0.0.1 in prod).

# --- Database (RDS PostgreSQL, private subnet) ---
# NOTE: the password must be URL-encoded if it contains special characters.
DATABASE_URL="postgresql://gethired:CHANGE_ME@gethired-db.xxxxxxxx.eu-west-2.rds.amazonaws.com:5432/gethired?schema=public&sslmode=require"

# --- Public URLs ---
# Your Vercel frontend. CORS is locked to this exact origin.
CLIENT_ORIGIN=https://www.gethired.uk
# This API's own public URL (used to build file URLs).
APP_BASE_URL=https://api.gethired.uk

# --- Auth secrets (openssl rand -base64 36) ---
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Cross-site cookies: ONLY needed if the frontend and API are on different
# sites (e.g. get-hired-uk.vercel.app + api.gethired.uk). If both share a
# parent domain (www.gethired.uk + api.gethired.uk), leave this unset.
# COOKIE_SAMESITE=none

# --- File storage: S3 (EC2 uses an IAM instance role — no keys needed) ---
STORAGE_DRIVER=s3
AWS_REGION=eu-west-2
AWS_S3_BUCKET=gethired-uk-documents
FILE_URL_SECRET=CHANGE_ME
SIGNED_URL_TTL_SECONDS=300

# --- Email (Daily Pulse, sign-up + lead notifications) ---
# Amazon SES SMTP (eu-west-2) or Resend/SendGrid.
SMTP_HOST=email-smtp.eu-west-2.amazonaws.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
MAIL_FROM="Get Hired UK <pulse@gethired.uk>"
PULSE_CRON="0 18 * * *"
PULSE_TIMEZONE=Europe/London
PULSE_SEND_ZERO=true

# --- AI cover-letter drafting (any OpenAI-compatible provider) ---
# Groq:  AI_BASE_URL=https://api.groq.com/openai/v1  AI_MODEL=llama-3.3-70b-versatile
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
MOCK_AI=false

# --- First admin (used once by `npm run seed`) ---
ADMIN_EMAIL=admin@gethired.uk
ADMIN_NAME=Portal Administrator
# Leave ADMIN_PASSWORD unset to have a strong one generated and printed once.
# ADMIN_PASSWORD=
