# --- Database ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gethired?schema=public"

# --- Server ---
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:4000

# --- Auth ---
JWT_ACCESS_SECRET=<generate-a-long-random-secret>
JWT_REFRESH_SECRET=<generate-a-long-random-secret>
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# --- File storage ---
# STORAGE_DRIVER=s3 requires the AWS_* vars below; "local" stores under ./uploads
STORAGE_DRIVER=local
FILE_URL_SECRET=<generate-a-long-random-secret>
SIGNED_URL_TTL_SECONDS=300
# AWS_REGION=eu-west-2
# AWS_S3_BUCKET=gethired-files
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT=            # set for Cloudflare R2

# --- Email (Daily Pulse) ---
# When SMTP_HOST is empty, emails are logged to the console (dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Get Hired UK <pulse@gethired.uk>"
PULSE_CRON="0 18 * * *"
PULSE_TIMEZONE=Europe/London
PULSE_SEND_ZERO=true

# --- AI ---
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
# MOCK_AI=true generates a local template draft when no API key is configured (testing only)
MOCK_AI=false
